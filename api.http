### SpotSync API REST Client Testing File
# Use this with the VS Code "REST Client" extension or convert to Postman/Insomnia.

@baseUrl = http://localhost:8080/api/v1

### 1. Register Driver
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "John Driver",
  "email": "john.driver@example.com",
  "password": "password123",
  "role": "driver"
}

### 2. Register Admin
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Jane Admin",
  "email": "jane.admin@example.com",
  "password": "password123",
  "role": "admin"
}

### 3. Login as Driver (To obtain JWT token)
# Save the returned token in the variables below
# @name driverLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john.driver@example.com",
  "password": "password123"
}

### 4. Login as Admin (To obtain JWT token)
# Save the returned token in the variables below
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "jane.admin@example.com",
  "password": "password123"
}

### Assign token variables from Login response if using REST Client variables:
@driverToken = {{driverLogin.response.body.data.token}}
@adminToken = {{adminLogin.response.body.data.token}}

### 5. Create Parking Zone (Admin Only)
# Change the authorization token as needed
POST {{baseUrl}}/zones
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "EV Zone Airport Terminal 1",
  "type": "ev_charging",
  "total_capacity": 3,
  "price_per_hour": 150.00
}

### 6. Get All Parking Zones (Public)
GET {{baseUrl}}/zones
Content-Type: application/json

### 7. Get Single Parking Zone (Public)
# Replace '1' with your active zone ID
GET {{baseUrl}}/zones/1
Content-Type: application/json

### 8. Create Reservation (Driver Only)
POST {{baseUrl}}/reservations
Content-Type: application/json
Authorization: Bearer {{driverToken}}

{
  "zone_id": 1,
  "license_plate": "METRO-KA-9912"
}

### 9. View My Reservations (Driver Only)
GET {{baseUrl}}/reservations/my-reservations
Content-Type: application/json
Authorization: Bearer {{driverToken}}

### 10. Cancel Reservation (Driver/Admin)
# Replace '1' with your active reservation ID
DELETE {{baseUrl}}/reservations/1
Content-Type: application/json
Authorization: Bearer {{driverToken}}

### 11. View All Reservations (Admin Only)
GET {{baseUrl}}/reservations
Content-Type: application/json
Authorization: Bearer {{adminToken}}
